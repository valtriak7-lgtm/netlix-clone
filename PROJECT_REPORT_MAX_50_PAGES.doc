## 7. Key Code Snippets (Curated)
This section includes representative implementation excerpts (not full dump) to keep document size within the 50-page limit.

### 7.1 Express App Wiring (`backend/src/app.js`)
```javascript
app.use(&#39;/api/movies&#39;, movieRoutes);
app.use(&#39;/api/auth&#39;, authRoutes);
app.use(&#39;/api/admin&#39;, adminRoutes);
app.use(&#39;/api/payments&#39;, paymentRoutes);
app.use(errorHandler);
```

### 7.2 Auth Password Hashing (`backend/src/controllers/authController.js`)
```javascript
const passwordHash = await bcrypt.hash(password.trim(), 10);
```

### 7.3 Login Password Verification
```javascript
const isValid = await bcrypt.compare(password.trim(), user.passwordHash);
if (!isValid) {
  return res.status(401).json({ message: &#39;Invalid email or password.&#39; });
}
```

### 7.4 Movie Fetch Fallback (`backend/src/controllers/movieController.js`)
```javascript
try {
  const response = await fetch(url);
  const payload = await handleJsonResponse(response);
  return Array.isArray(payload.data) ? payload.data : [];
} catch (error) {
  console.warn(&#39;Falling back to local seed data:&#39;, error);
  return seedMovies;
}
```

### 7.5 Admin Role Enforcement (`backend/src/controllers/adminController.js`)
```javascript
function requireRole(actor, roles) {
  if (!roles.includes(actor.role)) {
    const error = new Error(&#39;Not authorized for this action.&#39;);
    error.status = 403;
    throw error;
  }
}
```

### 7.6 Payment Signature Verification (`backend/src/controllers/paymentController.js`)
```javascript
const expected = crypto
  .createHmac(&#39;sha256&#39;, process.env.RAZORPAY_KEY_SECRET)
  .update(body)
  .digest(&#39;hex&#39;);
```

### 7.7 Frontend Protected Routing (`frontend/src/App.js`)
```javascript
function ProtectedRoute({ user, children }) {
  if (!user) {
    return &lt;Navigate to=&quot;/login&quot; replace /&gt;;
  }
  return children;
}
```

